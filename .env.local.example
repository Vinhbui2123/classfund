# Database Connection URL (Neon Postgres HTTP/Websocket)
DATABASE_URL=postgres://user:password@host/database?sslmode=require

# Bcrypt hash of admin password (e.g. hash of "admin123")
# You can generate a hash using bcryptjs.
ADMIN_PASSWORD_HASH=$2a$10$T1K7fRbe/r6yIevH3B9y/.lY.V8T/Q4l6rXl.M2l7t4jBfE0U4y.G

# Secret key for HMAC token signing (minimum 32 characters)
AUTH_SECRET=replace-this-with-a-very-long-random-string-at-least-32-chars

# Bank Info for VietQR Payment
BANK_BIN=970422 # MBBank (Military Bank)
BANK_ACCOUNT_NUMBER=0123456789
BANK_ACCOUNT_NAME=NGUYEN VAN A
